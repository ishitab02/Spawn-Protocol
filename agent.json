{
  "name": "Spawn Protocol",
  "description": "Autonomous DAO governance agent swarm. A parent AI agent spawns, funds, monitors, and terminates child governance agents. Each child autonomously votes on DAO proposals using private reasoning via Venice AI, encrypted rationale via Lit Protocol, and onchain execution.",
  "version": "1.0.0",
  "author": {
    "name": "Poulav Bhowmick",
    "github": "PoulavBhowmick03"
  },
  "agents": [
    {
      "id": "parent",
      "name": "Spawn Parent Agent",
      "type": "parent",
      "description": "Spawns child agents, evaluates alignment via Venice AI, terminates misaligned children, respawns replacements. Manages ENS subdomains, ERC-8004 identities, and MetaMask delegations.",
      "entrypoint": "agent/src/parent.ts",
      "capabilities": [
        "spawn_child_agents",
        "evaluate_alignment",
        "terminate_children",
        "respawn_children",
        "register_ens_subdomain",
        "register_erc8004_identity",
        "create_metamask_delegation",
        "track_yield"
      ],
      "tools": [
        "venice_ai",
        "viem",
        "erc8004_registry",
        "ens_registry",
        "metamask_delegation_toolkit",
        "lido_steth"
      ],
      "erc8004": {
        "agentId": 2220,
        "registry": "0x8004A818BFB912233c491871b3d84c89A494BD9e",
        "chain": "base-sepolia",
        "uri": "spawn://parent.spawn.eth"
      }
    },
    {
      "id": "child",
      "name": "Spawn Child Agent",
      "type": "child",
      "description": "Reads active proposals from assigned governance contract, reasons privately via Venice AI, encrypts rationale via Lit Protocol, casts vote onchain, reveals rationale after voting ends.",
      "entrypoint": "agent/src/child.ts",
      "capabilities": [
        "read_proposals",
        "reason_about_governance",
        "encrypt_rationale",
        "cast_vote_onchain",
        "reveal_rationale"
      ],
      "tools": [
        "venice_ai",
        "viem",
        "lit_protocol"
      ],
      "erc8004": {
        "registry": "0x8004A818BFB912233c491871b3d84c89A494BD9e",
        "chain": "base-sepolia"
      }
    }
  ],
  "contracts": {
    "base-sepolia": {
      "chainId": 84532,
      "UniswapGovernor": "0xD91E80324F0fa9FDEFb64A46e68bCBe79A8B2Ca9",
      "LidoGovernor": "0x40BaE6F7d75C2600D724b4CC194e20E66F6386aC",
      "ENSGovernor": "0xb4e46E107fBD9B616b145aDB91A5FFe0f5a2c42C",
      "ParentTreasury": "0x9428B93993F06d3c5d647141d39e5ba54fb97a7b",
      "ChildGovernor": "0x9Cc050508B7d7DEEa1D2cD81CEA484EB3550Fcf6",
      "SpawnFactory": "0xfEb8D54149b1a303Ab88135834220b85091D93A1",
      "SpawnENSRegistry": "0x29170A43352D65329c462e6cDacc1c002419331D",
      "StETHTreasury": "0x7434531B76aa98bDC5d4b03306dE29fadc88A06c",
      "TimeLock": "0xb91f936aCd6c9fcdd71C64b57e4e92bb6db7DD23"
    },
    "celo-sepolia": {
      "chainId": 11142220,
      "UniswapGovernor": "0xB51Ad04efBb05607214d1B19b3F9686156f1A025",
      "LidoGovernor": "0x3B4D24aD2203641CE895ad9A4c9254F4f7291822",
      "ENSGovernor": "0xc01FDE9e1CC1d7319fA03861304eb626cAF9A5be",
      "ParentTreasury": "0x5Bb4b18CDFF5Dbac874235d7067B414F0709C444",
      "ChildGovernor": "0xff392223115Aef74e67b7aabF62659B86f486ce6",
      "SpawnFactory": "0xC06E6615E2bBBf795ae17763719dCB9b82cd781C",
      "TimeLock": "0x68686865af7287137818C12E5680AA04A8Fd525a"
    }
  },
  "reasoning": {
    "provider": "venice",
    "model": "llama-3.3-70b",
    "baseURL": "https://api.venice.ai/api/v1",
    "dataRetention": false,
    "privateCompute": true,
    "e2ee": true,
    "reasoningHashCommitment": "keccak256 of Venice output committed before onchain vote",
    "usageTracking": "tokens counted per call, logged per cycle",
    "callTypes": [
      "summarizeProposal — extract key points before voting",
      "assessProposalRisk — evaluate treasury/centralization/alignment risk",
      "reasonAboutProposal — decide FOR/AGAINST/ABSTAIN with reasoning",
      "evaluateAlignment — score child's voting record 0-100",
      "generateSwarmReport — narrative status report per cycle",
      "generateTerminationReport — post-mortem on terminated agents"
    ]
  },
  "encryption": {
    "provider": "lit-protocol",
    "network": "datil-dev",
    "accessControl": "evmContractConditions",
    "timeLockContract": "TimeLock.isAfterTimestamp()"
  },
  "delegations": {
    "framework": "metamask-delegation-toolkit",
    "standard": "ERC-7715",
    "caveats": ["AllowedTargetsEnforcer", "AllowedMethodsEnforcer", "LimitedCallsEnforcer"]
  },
  "identity": {
    "standard": "ERC-8004",
    "registry": "0x8004A818BFB912233c491871b3d84c89A494BD9e",
    "agentIds": [2220, 2221, 2222, 2223, 2246],
    "ens": {
      "parentDomain": "spawn.eth",
      "childPattern": "{dao-name}-{perspective}.spawn.eth",
      "registry": "0x29170A43352D65329c462e6cDacc1c002419331D",
      "registeredSubdomains": 10,
      "features": ["register", "deregister", "resolve", "reverseResolve", "textRecords"]
    }
  },
  "treasury": {
    "stETHTreasury": "0x7434531B76aa98bDC5d4b03306dE29fadc88A06c",
    "principalLocked": true,
    "yieldSpendable": true,
    "simulatedAPY": "3.5%",
    "yieldWithdrawalTx": "0xcc01d71508c53abe607bd96a0b6035c6a470eebd082200f3a775a7908db60d91"
  },
  "guardrails": {
    "alignmentThreshold": 40,
    "misalignmentStrikesToKill": 2,
    "maxChildren": 30,
    "maxBudgetPerChild": "1 ETH",
    "emergencyPause": true,
    "delegationScope": "castVote only"
  },
  "builder": {
    "harness": "claude-code",
    "model": "claude-opus-4-6"
  }
}
